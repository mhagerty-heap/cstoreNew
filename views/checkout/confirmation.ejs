<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container py-5">
  <%- include('../partials/flash') %>

  <div class="text-center mb-5" id="order-confirmation-header">
    <div class="display-1 text-success mb-3">
      <i class="bi bi-check-circle-fill"></i>
    </div>
    <h1 class="fw-bold">Order Confirmed!</h1>
    <p class="lead text-muted">Thank you for your purchase. Your order has been received.</p>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
          <div class="row text-center g-3 mb-4" id="order-summary-bar">
            <div class="col-md-3 col-6">
              <div class="text-muted small">Order Number</div>
              <div class="fw-bold text-primary" id="confirmation-order-number"><%= order.order_number %></div>
            </div>
            <div class="col-md-3 col-6">
              <div class="text-muted small">Date</div>
              <div class="fw-semibold"><%= new Date(order.created_at).toLocaleDateString() %></div>
            </div>
            <div class="col-md-3 col-6">
              <div class="text-muted small">Total</div>
              <div class="fw-bold text-success fs-5">$<%= parseFloat(order.total).toFixed(2) %></div>
            </div>
            <div class="col-md-3 col-6">
              <div class="text-muted small">Payment</div>
              <div class="fw-semibold text-capitalize"><%= order.payment_method === 'cod' ? 'Cash on Delivery' : 'Credit Card' %></div>
            </div>
          </div>

          <!-- Order Items -->
          <h6 class="fw-bold mb-3">Items Ordered</h6>
          <div class="table-responsive">
            <table class="table table-sm">
              <thead class="bg-light">
                <tr>
                  <th>Product</th>
                  <th class="text-center">Qty</th>
                  <th class="text-end">Price</th>
                  <th class="text-end">Subtotal</th>
                </tr>
              </thead>
              <tbody>
                <% orderItems.forEach(item => { %>
                  <tr>
                    <td><%= item.name %></td>
                    <td class="text-center"><%= item.quantity %></td>
                    <td class="text-end">$<%= parseFloat(item.price).toFixed(2) %></td>
                    <td class="text-end">$<%= parseFloat(item.subtotal).toFixed(2) %></td>
                  </tr>
                <% }) %>
              </tbody>
              <tfoot class="fw-bold">
                <% if (order.discount > 0) { %>
                  <tr class="text-success">
                    <td colspan="3">Discount</td>
                    <td class="text-end">-$<%= parseFloat(order.discount).toFixed(2) %></td>
                  </tr>
                <% } %>
                <tr>
                  <td colspan="3">Shipping</td>
                  <td class="text-end"><%= order.shipping === 0 ? 'FREE' : '$' + parseFloat(order.shipping).toFixed(2) %></td>
                </tr>
                <tr>
                  <td colspan="3">Tax</td>
                  <td class="text-end">$<%= parseFloat(order.tax).toFixed(2) %></td>
                </tr>
                <tr class="table-primary">
                  <td colspan="3">Total</td>
                  <td class="text-end fs-5">$<%= parseFloat(order.total).toFixed(2) %></td>
                </tr>
              </tfoot>
            </table>
          </div>

          <!-- Shipping Address -->
          <h6 class="fw-bold mb-2 mt-3">Shipping To</h6>
          <p class="mb-0">
            <strong><%= order.shipping_name %></strong><br>
            <%= order.shipping_address %><br>
            <%= order.shipping_city %><% if (order.shipping_state) { %>, <%= order.shipping_state %><% } %> <%= order.shipping_zip %><br>
            <%= order.shipping_country %>
          </p>
        </div>
      </div>

      <div class="text-center d-flex gap-3 justify-content-center">
        <a href="/shop" class="btn btn-primary btn-lg" id="confirmation-continue-shopping">
          <i class="bi bi-bag2 me-2"></i>Continue Shopping
        </a>
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <a href="/orders" class="btn btn-outline-secondary btn-lg">
            <i class="bi bi-list-ul me-2"></i>My Orders
          </a>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
