<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container py-4">
  <h2 class="fw-bold mb-4"><i class="bi bi-heart me-2 text-danger"></i>My Wishlist</h2>
  <%- include('partials/flash') %>

  <% if (!items || items.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-heart display-3 text-muted"></i>
      <h4 class="mt-3 text-muted">Your wishlist is empty</h4>
      <p class="text-muted mb-4">Save items you love for later.</p>
      <a href="/shop" class="btn btn-primary btn-lg">
        <i class="bi bi-bag2 me-2"></i>Start Shopping
      </a>
    </div>
  <% } else { %>
    <div class="row g-4">
      <% items.forEach(item => { %>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="card border-0 shadow-sm h-100">
            <div class="position-relative">
              <a href="/product/<%= item.slug %>">
                <img src="<%= item.image_url || 'https://picsum.photos/seed/' + item.product_id + '/400/300' %>"
                     class="card-img-top" alt="<%= item.name %>"
                     style="height:220px; object-fit:cover;">
              </a>
              <form action="/wishlist/remove" method="POST" class="position-absolute top-0 end-0 m-2">
                <input type="hidden" name="product_id" value="<%= item.product_id %>">
                <button type="submit" class="btn btn-light btn-sm rounded-circle shadow-sm" title="Remove from wishlist">
                  <i class="bi bi-x text-danger"></i>
                </button>
              </form>
            </div>
            <div class="card-body d-flex flex-column">
              <a href="/product/<%= item.slug %>" class="text-dark text-decoration-none fw-semibold mb-1">
                <%= item.name %>
              </a>
              <div class="mt-auto">
                <div class="fw-bold text-primary mb-2">
                  $<%= parseFloat(item.price).toFixed(2) %>
                  <% if (item.compare_price && item.compare_price > item.price) { %>
                    <small class="text-muted text-decoration-line-through ms-1">$<%= parseFloat(item.compare_price).toFixed(2) %></small>
                  <% } %>
                </div>
                <form action="/cart/add" method="POST">
                  <input type="hidden" name="product_id" value="<%= item.product_id %>">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="btn btn-primary w-100 btn-sm" <%= item.stock === 0 ? 'disabled' : '' %>>
                    <i class="bi bi-cart-plus me-1"></i>
                    <%= item.stock === 0 ? 'Out of Stock' : 'Add to Cart' %>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
</body>
</html>
