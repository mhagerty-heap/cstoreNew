<!-- Top bar -->
<div class="top-bar">
  <div class="container d-flex justify-content-between align-items-center">
    <span><i class="bi bi-telephone me-1"></i>1 800 345 6789</span>
    <span class="top-promo d-none-mobile"><i class="bi bi-truck me-1"></i>FREE SHIPPING ON ORDERS OVER $99</span>
    <div class="d-flex gap-3">
      <% if (typeof currentUser !== 'undefined' && currentUser) { %>
        <a href="<%= currentUser.role === 'admin' ? '/admin' : '/orders' %>"><i class="bi bi-person me-1"></i><%= currentUser.name.split(' ')[0] %></a>
        <a href="/logout"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
      <% } else { %>
        <a href="/login"><i class="bi bi-person me-1"></i>Sign In</a>
        <a href="/register">Register</a>
      <% } %>
    </div>
  </div>
</div>

<!-- Main nav -->
<header class="main-nav">
  <div class="container d-flex align-items-center gap-4">
    <!-- Logo -->
    <a href="/" class="navbar-brand me-3 flex-shrink-0" id="main-logo">
      C<span>Store</span>
    </a>

    <!-- Search -->
    <form class="search-bar d-flex flex-grow-1" action="/shop" method="GET" id="search-form">
      <input class="form-control" type="search" name="q" id="search-input"
             placeholder="Search products, brands and categories..."
             value="<%= typeof filters !== 'undefined' && filters.q ? filters.q : '' %>">
      <button class="btn-search" type="submit" id="search-submit"><i class="bi bi-search"></i></button>
    </form>

    <!-- Icons -->
    <div class="nav-icons d-flex align-items-center ms-3">
      <!-- Wishlist -->
      <a href="/wishlist" title="Wishlist" id="nav-wishlist-link">
        <i class="bi bi-heart<%= (typeof wishlistCount !== 'undefined' && wishlistCount > 0) ? '-fill text-danger' : '' %>"></i>
        <span>Wishlist</span>
      </a>
      <!-- Cart -->
      <a href="/cart" title="Cart" class="ms-1 position-relative" id="nav-cart-link">
        <i class="bi bi-cart2"></i>
        <span class="cart-total-text">
          $<%= (typeof cartTotal !== 'undefined' ? cartTotal : 0).toFixed(2) %>
        </span>
        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
          <span class="badge-pill" id="cart-count"><%= cartCount %></span>
        <% } else { %>
          <span class="badge-pill d-none" id="cart-count">0</span>
        <% } %>
      </a>
    </div>
  </div>
</header>

<!-- Category nav -->
<div class="cat-nav">
  <div class="container">
    <nav class="navbar navbar-expand-lg p-0">
      <button class="navbar-toggler border-0 py-2 me-2" type="button" data-bs-toggle="collapse" data-bs-target="#catNavMenu">
        <i class="bi bi-list fs-4"></i>
      </button>
      <div class="collapse navbar-collapse" id="catNavMenu">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/shop" id="nav-all-products">All Products</a>
          </li>
          <% if (typeof navCategories !== 'undefined') { %>
            <% navCategories.filter(c => !c.parent_id).forEach(cat => { %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="/shop?category=<%= cat.slug %>" data-bs-toggle="dropdown" id="nav-cat-<%= cat.slug %>">
                  <%= cat.name %>
                </a>
                <ul class="dropdown-menu">
                  <li><a class="dropdown-item" href="/shop?category=<%= cat.slug %>" id="nav-cat-<%= cat.slug %>-all">All <%= cat.name %></a></li>
                  <% navCategories.filter(c => c.parent_id === cat.id).forEach(sub => { %>
                    <li><a class="dropdown-item" href="/shop?category=<%= sub.slug %>" id="nav-cat-<%= sub.slug %>"><%= sub.name %></a></li>
                  <% }) %>
                </ul>
              </li>
            <% }) %>
          <% } %>
          <li class="nav-item">
            <a class="nav-link" href="/shop?on_sale=1" style="color: var(--red) !important;" id="nav-sale-link">Sale</a>
          </li>
        </ul>
        <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'admin') { %>
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link" href="/admin" style="color: var(--red) !important;">
                <i class="bi bi-speedometer2 me-1"></i>Admin
              </a>
            </li>
          </ul>
        <% } %>
      </div>
    </nav>
  </div>
</div>
