<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Categories - ShopExpress Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<div class="d-flex">
  <% const activePage = 'categories'; %>
  <%- include('../sidebar') %>
  <div class="flex-grow-1 bg-light" style="min-height:100vh;">
    <div class="bg-white border-bottom px-4 py-3 d-flex justify-content-between align-items-center">
      <h5 class="mb-0 fw-bold"><i class="bi bi-tags me-2 text-primary"></i>Categories</h5>
      <a href="/admin/categories/new" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Add Category
      </a>
    </div>
    <div class="p-4">
      <%- include('../../partials/flash') %>
      <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
          <table class="table mb-0 align-middle">
            <thead class="bg-light">
              <tr>
                <th class="ps-3 py-3">Name</th>
                <th class="py-3">Slug</th>
                <th class="py-3">Parent</th>
                <th class="py-3 text-center">Products</th>
                <th class="py-3 text-end pe-3">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!categories || categories.length === 0) { %>
                <tr><td colspan="5" class="text-center py-4 text-muted">No categories yet. <a href="/admin/categories/new">Create one</a></td></tr>
              <% } else { %>
                <% categories.forEach(cat => { %>
                  <tr>
                    <td class="ps-3">
                      <span class="<%= cat.parent_id ? 'ms-3 text-muted' : 'fw-semibold' %>">
                        <% if (cat.parent_id) { %><i class="bi bi-arrow-return-right me-1 text-muted small"></i><% } %>
                        <%= cat.name %>
                      </span>
                    </td>
                    <td class="text-muted small font-monospace"><%= cat.slug %></td>
                    <td class="text-muted small"><%= cat.parent_name || '—' %></td>
                    <td class="text-center">
                      <span class="badge bg-secondary rounded-pill"><%= cat.product_count %></span>
                    </td>
                    <td class="text-end pe-3">
                      <a href="/admin/categories/<%= cat.id %>/edit" class="btn btn-outline-primary btn-sm me-1">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form action="/admin/categories/<%= cat.id %>?_method=DELETE" method="POST" class="d-inline"
                            onsubmit="return confirm('Delete this category?')">
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                          <i class="bi bi-trash3"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
