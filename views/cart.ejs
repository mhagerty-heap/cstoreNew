<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container py-4">
  <h2 class="fw-bold mb-4"><i class="bi bi-cart3 me-2"></i>Shopping Cart</h2>
  <%- include('partials/flash') %>

  <% if (coupon) { %>
    <div class="alert alert-success d-flex justify-content-between align-items-center py-2 mb-3" id="cart-coupon-applied">
      <span><i class="bi bi-tag-fill me-2"></i>Coupon <strong><%= coupon.code %></strong> applied — saving $<%= parseFloat(discount).toFixed(2) %></span>
      <form action="/coupon/remove" method="POST" class="mb-0">
        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
      </form>
    </div>
  <% } else { %>
    <div class="card border-0 shadow-sm mb-3" id="cart-coupon-form">
      <div class="card-body p-3">
        <h6 class="fw-bold mb-2"><i class="bi bi-tag me-2"></i>Have a promo code?</h6>
        <div class="d-flex gap-2">
          <input type="text" class="form-control" id="couponCode" placeholder="Enter coupon code" style="max-width:260px;">
          <button class="btn btn-outline-primary" id="coupon-apply-btn" onclick="applyCoupon()">Apply</button>
        </div>
        <div id="couponMsg" class="mt-2 small"></div>
      </div>
    </div>
  <% } %>

  <% if (!items || items.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-cart-x display-3 text-muted"></i>
      <h4 class="mt-3">Your cart is empty</h4>
      <p class="text-muted mb-4">Add some products to get started!</p>
      <a href="/shop" class="btn btn-primary btn-lg">
        <i class="bi bi-bag2 me-2"></i>Continue Shopping
      </a>
    </div>
  <% } else { %>
    <div class="row g-4">
      <!-- Cart Items -->
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table mb-0">
                <thead class="bg-light">
                  <tr>
                    <th class="py-3 ps-3">Product</th>
                    <th class="py-3 text-center">Price</th>
                    <th class="py-3 text-center">Qty</th>
                    <th class="py-3 text-center">Subtotal</th>
                    <th class="py-3"></th>
                  </tr>
                </thead>
                <tbody>
                  <% items.forEach(item => { %>
                    <tr class="align-middle" id="cart-item-<%= item.id %>">
                      <td class="ps-3">
                        <div class="d-flex align-items-center gap-3">
                          <img src="<%= item.image_url || 'https://picsum.photos/seed/' + item.product_id + '/100/100' %>"
                               alt="<%= item.name %>"
                               class="rounded"
                               style="width:65px; height:60px; object-fit:cover;">
                          <div>
                            <a href="/product/<%= item.slug %>" class="fw-semibold text-dark text-decoration-none" id="cart-item-name-<%= item.id %>">
                              <%= item.name %>
                            </a>
                            <% if (item.variant_name) { %>
                              <div class="text-muted small"><%= item.variant_name %></div>
                            <% } %>
                          </div>
                        </div>
                      </td>
                      <td class="text-center">$<%= parseFloat(item.effective_price).toFixed(2) %></td>
                      <td class="text-center">
                        <form action="/cart/update" method="POST" class="d-flex align-items-center justify-content-center gap-1">
                          <input type="hidden" name="item_id" value="<%= item.id %>">
                          <button type="submit" name="quantity" value="<%= item.quantity - 1 %>" class="btn btn-light btn-sm border" id="cart-qty-decrease-<%= item.id %>">
                            <i class="bi bi-dash"></i>
                          </button>
                          <span class="px-2 fw-semibold" id="cart-qty-display-<%= item.id %>"><%= item.quantity %></span>
                          <button type="submit" name="quantity" value="<%= item.quantity + 1 %>" class="btn btn-light btn-sm border" id="cart-qty-increase-<%= item.id %>">
                            <i class="bi bi-plus"></i>
                          </button>
                        </form>
                      </td>
                      <td class="text-center fw-bold text-primary">
                        $<%= (item.effective_price * item.quantity).toFixed(2) %>
                      </td>
                      <td>
                        <form action="/cart/remove" method="POST">
                          <input type="hidden" name="item_id" value="<%= item.id %>">
                          <button type="submit" class="btn btn-link text-danger p-0" id="cart-remove-<%= item.id %>" title="Remove">
                            <i class="bi bi-trash3 fs-5"></i>
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>


        <div class="mt-3">
          <a href="/shop" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Continue Shopping
          </a>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-4">
            <h5 class="fw-bold mb-3">Order Summary</h5>
            <div class="d-flex justify-content-between mb-2">
              <span>Subtotal</span>
              <span>$<%= parseFloat(subtotal).toFixed(2) %></span>
            </div>
            <% if (discount > 0) { %>
              <div class="d-flex justify-content-between mb-2 text-success">
                <span>Discount</span>
                <span>-$<%= parseFloat(discount).toFixed(2) %></span>
              </div>
            <% } %>
            <div class="d-flex justify-content-between mb-2">
              <span>Shipping</span>
              <span class="<%= shipping === 0 ? 'text-success' : '' %>">
                <%= shipping === 0 ? 'FREE' : '$' + parseFloat(shipping).toFixed(2) %>
              </span>
            </div>
            <% if (shipping > 0) { %>
              <small class="text-muted d-block mb-2">
                Add $<%= (99 - (subtotal - discount)).toFixed(2) %> more for free shipping
              </small>
            <% } %>
            <div class="d-flex justify-content-between mb-2">
              <span>Tax (8%)</span>
              <span>$<%= parseFloat(tax).toFixed(2) %></span>
            </div>
            <hr>
            <div class="d-flex justify-content-between fw-bold fs-5">
              <span>Total</span>
              <span class="text-primary">$<%= parseFloat(total).toFixed(2) %></span>
            </div>
            <a href="/checkout" class="btn btn-primary btn-lg w-100 mt-3" id="proceed-to-checkout">
              <i class="bi bi-lock me-2"></i>Proceed to Checkout
            </a>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</div>

<script>
function applyCoupon() {
  const code = document.getElementById('couponCode').value.trim();
  const msgEl = document.getElementById('couponMsg');
  if (!code) { msgEl.innerHTML = '<span class="text-danger">Please enter a coupon code</span>'; return; }

  fetch('/coupon/apply', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ code, subtotal: <%= subtotal %> })
  })
  .then(r => r.json())
  .then(data => {
    if (data.success) {
      msgEl.innerHTML = '<span class="text-success"><i class="bi bi-check-circle me-1"></i>' + data.message + '</span>';
      setTimeout(() => { window.location.href = '/cart?action=coupon_applied'; }, 1000);
    } else {
      msgEl.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle me-1"></i>' + data.message + '</span>';
    }
  });
}
document.getElementById('couponCode')?.addEventListener('keypress', e => { if (e.key === 'Enter') { e.preventDefault(); applyCoupon(); } });
</script>

<%- include('partials/footer') %>
</body>
</html>
