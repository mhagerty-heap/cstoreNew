<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container py-5 text-center">
  <div class="py-5">
    <div class="display-1 fw-bold text-muted"><%= typeof status !== 'undefined' ? status : 500 %></div>
    <h2 class="fw-bold mt-2"><%= typeof title !== 'undefined' ? title : 'Error' %></h2>
    <p class="text-muted lead mb-4"><%= typeof message !== 'undefined' ? message : 'Something went wrong.' %></p>
    <div class="d-flex gap-3 justify-content-center">
      <a href="/" class="btn btn-primary btn-lg">
        <i class="bi bi-house me-2"></i>Go Home
      </a>
      <button onclick="history.back()" class="btn btn-outline-secondary btn-lg">
        <i class="bi bi-arrow-left me-2"></i>Go Back
      </button>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
</body>
</html>
