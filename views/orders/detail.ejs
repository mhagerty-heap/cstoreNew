<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">Home</a></li>
      <li class="breadcrumb-item"><a href="/orders">My Orders</a></li>
      <li class="breadcrumb-item active"><%= order.order_number %></li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-start mb-4">
    <div>
      <h2 class="fw-bold mb-1">Order <%= order.order_number %></h2>
      <span class="text-muted">Placed on <%= new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
    </div>
    <% const statusColors = { pending: 'warning', processing: 'info', shipped: 'primary', delivered: 'success', cancelled: 'danger' }; %>
    <span class="badge bg-<%= statusColors[order.status] || 'secondary' %> fs-6 text-capitalize px-3 py-2">
      <%= order.status %>
    </span>
  </div>

  <%- include('../partials/flash') %>

  <div class="row g-4">
    <!-- Items -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white fw-bold border-bottom py-3">
          <i class="bi bi-box-seam me-2"></i>Order Items
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table mb-0 align-middle">
              <thead class="bg-light">
                <tr>
                  <th class="ps-3 py-2">Product</th>
                  <th class="text-center py-2">Price</th>
                  <th class="text-center py-2">Qty</th>
                  <th class="text-end pe-3 py-2">Subtotal</th>
                </tr>
              </thead>
              <tbody>
                <% orderItems.forEach(item => { %>
                  <tr>
                    <td class="ps-3">
                      <div class="d-flex align-items-center gap-2">
                        <% if (item.image_url) { %>
                          <img src="<%= item.image_url %>" alt="" class="rounded" style="width:50px;height:45px;object-fit:cover">
                        <% } %>
                        <span class="fw-semibold"><%= item.name %></span>
                      </div>
                    </td>
                    <td class="text-center">$<%= parseFloat(item.price).toFixed(2) %></td>
                    <td class="text-center"><%= item.quantity %></td>
                    <td class="text-end pe-3 fw-bold">$<%= parseFloat(item.subtotal).toFixed(2) %></td>
                  </tr>
                <% }) %>
              </tbody>
              <tfoot class="border-top">
                <% if (order.discount > 0) { %>
                  <tr><td colspan="3" class="text-end text-success pe-3">Discount</td><td class="text-end text-success pe-3">-$<%= parseFloat(order.discount).toFixed(2) %></td></tr>
                <% } %>
                <tr><td colspan="3" class="text-end pe-3">Shipping</td><td class="text-end pe-3"><%= order.shipping === 0 ? 'FREE' : '$' + parseFloat(order.shipping).toFixed(2) %></td></tr>
                <tr><td colspan="3" class="text-end pe-3">Tax</td><td class="text-end pe-3">$<%= parseFloat(order.tax).toFixed(2) %></td></tr>
                <tr class="fw-bold fs-5"><td colspan="3" class="text-end pe-3 py-2">Total</td><td class="text-end text-primary pe-3 py-2">$<%= parseFloat(order.total).toFixed(2) %></td></tr>
              </tfoot>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Info -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white fw-bold border-bottom py-3">
          <i class="bi bi-house me-2"></i>Shipping Address
        </div>
        <div class="card-body">
          <p class="mb-0">
            <strong><%= order.shipping_name %></strong><br>
            <%= order.shipping_address %><br>
            <%= order.shipping_city %><% if (order.shipping_state) { %>, <%= order.shipping_state %><% } %> <%= order.shipping_zip %><br>
            <%= order.shipping_country %>
          </p>
        </div>
      </div>
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-bold border-bottom py-3">
          <i class="bi bi-credit-card me-2"></i>Payment Info
        </div>
        <div class="card-body">
          <p class="mb-1"><strong>Method:</strong> <%= order.payment_method === 'cod' ? 'Cash on Delivery' : 'Credit Card' %></p>
          <% if (order.coupon_code) { %>
            <p class="mb-0"><strong>Coupon:</strong> <span class="badge bg-success"><%= order.coupon_code %></span></p>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <a href="/orders" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-2"></i>Back to Orders
    </a>
    <a href="/shop" class="btn btn-primary ms-2">
      <i class="bi bi-bag2 me-2"></i>Continue Shopping
    </a>
  </div>
</div>

<%- include('../partials/footer') %>
</body>
</html>
