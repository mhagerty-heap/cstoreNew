<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<div class="container py-4">
  <h2 class="fw-bold mb-4"><i class="bi bi-bag me-2"></i>My Orders</h2>
  <%- include('../partials/flash') %>

  <% if (!orders || orders.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-bag-x display-3 text-muted"></i>
      <h4 class="mt-3 text-muted">No orders yet</h4>
      <p class="text-muted mb-4">You haven't placed any orders. Start shopping!</p>
      <a href="/shop" class="btn btn-primary btn-lg">
        <i class="bi bi-bag2 me-2"></i>Shop Now
      </a>
    </div>
  <% } else { %>
    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table mb-0 align-middle">
          <thead class="bg-light">
            <tr>
              <th class="py-3 ps-4">Order #</th>
              <th class="py-3">Date</th>
              <th class="py-3">Status</th>
              <th class="py-3">Total</th>
              <th class="py-3">Payment</th>
              <th class="py-3 text-end pe-4">Action</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(order => { %>
              <tr>
                <td class="ps-4">
                  <a href="/orders/<%= order.order_number %>" class="fw-semibold text-decoration-none">
                    <%= order.order_number %>
                  </a>
                </td>
                <td><%= new Date(order.created_at).toLocaleDateString() %></td>
                <td>
                  <% const statusColors = { pending: 'warning', processing: 'info', shipped: 'primary', delivered: 'success', cancelled: 'danger' }; %>
                  <span class="badge bg-<%= statusColors[order.status] || 'secondary' %> text-capitalize">
                    <%= order.status %>
                  </span>
                </td>
                <td class="fw-bold text-primary">$<%= parseFloat(order.total).toFixed(2) %></td>
                <td class="text-capitalize text-muted small"><%= order.payment_method === 'cod' ? 'Cash on Delivery' : 'Credit Card' %></td>
                <td class="text-end pe-4">
                  <a href="/orders/<%= order.order_number %>" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-eye me-1"></i>View
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
</body>
</html>
