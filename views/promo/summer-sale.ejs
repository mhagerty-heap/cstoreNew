<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main>
  <!-- Hero Banner -->
  <div class="promo-hero" style="background-image:url('/images/sale_carousel.jpg'); background-size:cover; background-position:center; min-height:480px; display:flex; align-items:center; position:relative;">
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);"></div>
    <div class="container position-relative text-white text-center py-5">
      <span class="badge bg-danger fs-6 mb-3 px-3 py-2">Limited Time</span>
      <h1 class="display-4 fw-bold mb-3">Summer Sale</h1>
      <p class="lead mb-2">Up to 40% off on selected styles.</p>
      <p class="mb-4 fs-5">Use code <strong class="text-warning">SAVE10</strong> at checkout for an extra 10% off your order.</p>
      <a href="/shop" class="btn btn-warning btn-lg px-5 fw-semibold" id="promo-summer-sale-cta">Shop the Sale</a>
    </div>
  </div>

  <!-- Details Section -->
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8 text-center">
        <h2 class="fw-bold mb-3">Don't Miss Out</h2>
        <p class="text-muted fs-5 mb-4">Our biggest sale of the season is here. Stock up on your favourite brands — Nike, Adidas, Vans, Converse and more — at prices you won't find anywhere else.</p>
        <div class="row g-4 mb-5">
          <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4 text-center">
              <i class="bi bi-tag-fill fs-2 text-danger mb-3"></i>
              <h5 class="fw-semibold">Up to 40% Off</h5>
              <p class="text-muted small mb-0">Hundreds of styles marked down for a limited time.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4 text-center">
              <i class="bi bi-percent fs-2 text-warning mb-3"></i>
              <h5 class="fw-semibold">Extra 10% with SAVE10</h5>
              <p class="text-muted small mb-0">Apply code <strong>SAVE10</strong> at checkout on top of sale prices.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 p-4 text-center">
              <i class="bi bi-truck fs-2 text-success mb-3"></i>
              <h5 class="fw-semibold">Free Shipping</h5>
              <p class="text-muted small mb-0">On all orders over $50. Fast, tracked delivery.</p>
            </div>
          </div>
        </div>
        <a href="/shop" class="btn btn-dark btn-lg px-5 fw-semibold" id="promo-summer-sale-cta-bottom">Browse All Sale Items</a>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
